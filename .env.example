# ==============================================================================
# BPSquare LLC — Environment Variables Example
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ==============================================================================

# --- WordPress / MySQL ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=bpsquare_wp
MYSQL_USER=bpsquare
MYSQL_PASSWORD=changeme_db

WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=bpsquare_wp
WORDPRESS_DB_USER=bpsquare
WORDPRESS_DB_PASSWORD=changeme_db

WORDPRESS_TABLE_PREFIX=bp_
WORDPRESS_DEBUG=true

# WordPress secret keys (generate at https://api.wordpress.org/secret-key/1.1/salt/)
WORDPRESS_AUTH_KEY=put-a-random-string-here
WORDPRESS_SECURE_AUTH_KEY=put-a-random-string-here
WORDPRESS_LOGGED_IN_KEY=put-a-random-string-here
WORDPRESS_NONCE_KEY=put-a-random-string-here
WORDPRESS_AUTH_SALT=put-a-random-string-here
WORDPRESS_SECURE_AUTH_SALT=put-a-random-string-here
WORDPRESS_LOGGED_IN_SALT=put-a-random-string-here
WORDPRESS_NONCE_SALT=put-a-random-string-here

# BPSquare Plugin Settings
BPSQUARE_ADMIN_EMAIL=admin@bpsquarellc.com
BPSQUARE_FROM_EMAIL=noreply@bpsquarellc.com
BPSQUARE_FROM_NAME=BPSquare LLC

# --- Angular ---
# Used in angular/bpsquare-frontend/src/environments/
ANGULAR_WP_API_URL=http://localhost:8080/wp-json
ANGULAR_SITE_URL=http://localhost:4200

# --- Production overrides (set on your server, not here) ---
# WORDPRESS_DEBUG=false
# ANGULAR_WP_API_URL=https://bpsquarellc.com/wp-json
# ANGULAR_SITE_URL=https://bpsquarellc.com
